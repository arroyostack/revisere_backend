PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# AI Provider Configuration
# Supported providers: openai, anthropic, groq, google, minimax
AI_PROVIDER=minimax
AI_API_KEY=
AI_MODEL_IDENTIFIER=

# Logging Configuration
# Supported log levels: error, warn, info, debug, verbose
LOG_LEVEL=info

# Rate Limiting Configuration
# Maximum requests per IP address within the time window
RATE_LIMIT_MAX_REQUESTS=20
# Time window for rate limiting in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# AI Budget Protection Configuration
# Maximum AI calls allowed across all users per day (prevents runaway costs)
AI_DAILY_CALL_BUDGET=500
# Maximum AI calls per IP address per day (default: 10 = ~3 contract analyses)
AI_PER_IP_DAILY_LIMIT=10
