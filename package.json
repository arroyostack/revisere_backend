{
  "name": "contractlens-backend",
  "version": "1.0.0",
  "description": "ContractLens Backend - AI-powered legal contract analysis API",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --incremental false",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/groq": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@types/uuid": "^10.0.0",
    "ai": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@vitest/coverage-istanbul": "^2.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0",
    "vitest-mock-extended": "^1.3.0"
  }
}
